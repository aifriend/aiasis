{
  "_meta": {
    "preset_name": "Interview Prep",
    "description": "Behavioral interview practice using STAR method. Question-feedback-retry cycle."
  },
  "audio": {
    "input_device": null,
    "output_device": null,
    "vad_threshold": 0.5,
    "audio_queue_max": 200
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "temperature": 0.6,
    "max_tokens": 300,
    "base_url": null,
    "api_version": null
  },
  "stt": {
    "deepgram_model": "flux-general-en",
    "eot_threshold": 0.7,
    "connection_retries": 3,
    "connection_timeout": 15
  },
  "tts": {
    "voice": "en-US-AriaNeural",
    "rate": "-15%",
    "volume": "-15%",
    "pitch": "+0Hz"
  },
  "session": {
    "trigger_interval_min": 7,
    "coaching_max_words": 80,
    "buffer_max_age_min": 15,
    "timer_check_interval_sec": 5,
    "tail_context_entries": 3,
    "no_observation_text": "No notable observations.",
    "debug_logs": false
  },
  "prompt": {
    "file": "prompts/v3.txt"
  }
}
